  <!-- Case Studies Section -->
  <!-- Delivered Project Section -->
  <section class="delivered container" id="delivered">

    <div class="section-header">
      <span class="badge-pill-large">
        <span class="dot"></span>
        Client Delivery
      </span>

      <h2 class="section-title">
        Delivered <span class="hl">Projects</span>
      </h2>

      <p class="section-subtitle">
        Real-world projects delivered to clients.
      </p>
    </div>

    <div class="delivered-list">

      <% deliveredProjects.forEach(project=> { %>

        <div class="delivered-item">

          <!-- LEFT SIDE -->
          <div class="delivered-content">

            <h3 class="delivered-title">
              <%= project.title %>
            </h3>

            <p class="delivered-desc">
              <%= project.description.length> 1000
                ? project.description.substring(0, 1000) + "..."
                : project.description %>
            </p>

            <% if (project.clientName) { %>
              <p class="delivered-client">
                Client: <strong>
                  <%= project.clientName %>
                </strong>
              </p>
              <% } %>

                <div class="delivered-actions">
                  <% if (project.liveLink) { %>
                    <a href="<%= project.liveLink %>" target="_blank" class="btn btn-primary">
                      View Live Project
                    </a>
                    <% } %>
                </div>

          </div>

          <!-- RIGHT SIDE -->
          <div class="delivered-media">
            <img src="<%= project.image.url %>" alt="<%= project.title %>">
          </div>

        </div>

        <% }) %>

    </div>

  </section>
  <!--   Projects section    -->
  <section class="projects container" id="projects">

    <div class="section-header">
      <h2 class="section-title">Featured <span class="hl">Projects</span></h2>
      <p class="section-subtitle">
        Product, web, and app builds designed for user engagement and business growth.
      </p>
    </div>

    <div class="projects-grid">
      <% projects.forEach(project=> { %>

        <!-- <div class="project-card"> -->
        <div class="project-card" onclick="goToProject('<%= project._id %>')">

          <div class="project-image">
            <img src="<%= project.image.url %>" alt="<%= project.title %>">
            <span class="project-badge">
              <%= project.category %>
            </span>

            <!-- FIXED ICON BUTTON -->
            <button class="project-overlay" onclick="event.stopPropagation(); goToProject('<%= project._id %>')">
              <i class="fas fa-arrow-right"></i>
            </button>
          </div>

          <!-- MAKE CONTENT CLICKABLE -->
          <div class="project-content" onclick="goToProject('<%= project._id %>')">
            <h3 class="project-title">
              <%= project.title %>
            </h3>

            <p class="project-desc">
              <% const plainText=project.description.replace(/<[^>]*>/g, ''); %>
                <%= plainText.length> 120
                  ? plainText.substring(0, 120) + "..."
                  : plainText %>
            </p>

            <div class="project-tags">
              <% project.technologies.forEach(tag=> { %>
                <span onclick="event.stopPropagation(); goToProject('<%= project._id %>')">
                  #<%= tag %>
                </span>
                <% }) %>
            </div>
          </div>

        </div>

        <% }) %>
    </div>

    <!-- Toggle Button -->
    <div class="projects-btn">
      <button id="toggleBtn" class="btn btn-outline">
        <i class="fas fa-plus"></i> Show More
      </button>
    </div>

  </section>

  <script>
    document.addEventListener("DOMContentLoaded", () => {

      const cards = document.querySelectorAll(".project-card");
      const btn = document.getElementById("toggleBtn");

      let expanded = false;

      function updateView() {
        cards.forEach((card, index) => {
          if (!expanded && index > 2) {
            card.style.display = "none";
          } else {
            card.style.display = "block";
          }
        });
      }

      updateView();

      btn.addEventListener("click", () => {
        expanded = !expanded;

        btn.innerHTML = expanded
          ? '<i class="fas fa-minus"></i> Show Less'
          : '<i class="fas fa-plus"></i> Show More';

        updateView();
      });

      // hide button if not needed
      if (cards.length <= 3) {
        btn.style.display = "none";
      }

    });
  </script>

