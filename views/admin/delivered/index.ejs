<% layout("layouts/boilerplate") %>

<div class="admin-wrapper">

  <!-- SIDEBAR -->
  <aside class="admin-sidebar">
    <h2 class="logo">Ali Sher Admin</h2>

    <nav>
      <a href="/admin/dashboard">Dashboard</a>
      <a href="/admin/projects">Projects</a>
      <a href="/admin/delivered" class="active">Delivered Projects</a>
      <a href="/admin/messages">Messages</a>
      <a href="/admin/logout" class="logout">Logout</a>
    </nav>
  </aside>

  <!-- MAIN -->
  <main class="admin-main">

    <div class="admin-header-flex">
      <div>
        <h1 class="admin-title">Delivered Projects</h1>
        <p class="admin-subtitle">Manage client delivered work.</p>
      </div>

      <a href="/admin/delivered/new" class="btn btn-primary add-project-btn">
        + Add Delivered Project
      </a>
    </div>

    <div class="table-container">
      <table class="admin-table">

        <thead>
          <tr>
            <th>Project</th>
            <th>Live Link</th>
            <th>Date</th>
            <th>Actions</th>
          </tr>
        </thead>

        <tbody>

          <% if (projects && projects.length > 0) { %>
            <% projects.forEach(project => { %>

              <tr>

                <!-- PROJECT COLUMN -->
                <td>
                  <div class="table-project-info">
                    <img src="<%= project.image.url %>" class="table-img">
                    
                    <div class="table-text">
                      <span class="p-name"><%= project.title %></span>
                      <span class="p-name">
                        <%= project.description.length > 50
                          ? project.description.substring(0, 50) + "..."
                          : project.description %>
                      </span>
                    </div>
                  </div>
                </td>

                <!-- CLIENT -->
               

                <!-- LIVE LINK -->
                <td>
                  <% if (project.liveLink) { %>
                    <a href="<%= project.liveLink %>" target="_blank" class="live-link">
                      View Live
                    </a>
                  <% } else { %>
                    <span class="muted">Not Available</span>
                  <% } %>
                </td>

                <!-- DATE -->
                <td class="table-date">
                  <%= project.createdAt
                    ? new Date(project.createdAt).toDateString()
                    : "N/A" %>
                </td>

                <!-- ACTIONS -->
                <td>
                  <div class="action-btns">

                    <a href="/admin/delivered/<%= project._id %>/edit" class="action-icon edit">
                     <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none"
                          stroke="currentColor" stroke-width="2">
                          <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                          <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
                        </svg>
                    </a>

                    <form action="/admin/delivered/<%= project._id %>?_method=DELETE"
                          method="POST"
                          style="display:inline;">
                      <button class="action-icon delete"
                              onclick="return confirm('Delete this project?')">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none"
                            stroke="currentColor" stroke-width="2">
                            <polyline points="3 6 5 6 21 6"></polyline>
                            <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2">
                            </path>
                            <line x1="10" y1="11" x2="10" y2="17"></line>
                            <line x1="14" y1="11" x2="14" y2="17"></line>
                          </svg>
                      </button>
                    </form>

                  </div>
                </td>

              </tr>

            <% }) %>
          <% } else { %>

            <tr>
              <td colspan="5" style="text-align:center; padding:30px;">
                No delivered projects yet.
              </td>
            </tr>

          <% } %>

        </tbody>

      </table>
    </div>

  </main>
</div>