<% layout("layouts/boilerplate") %>

<div class="admin-wrapper">

  <!-- SIDEBAR -->
  <aside class="admin-sidebar">
    <h2 class="logo">AliSher Admin</h2>

    <nav>
      <a href="/admin/dashboard">Dashboard</a>
      <a href="/admin/projects">Projects</a>
      <a href="/admin/delivered" class="active">Delivered Projects</a>
      <a href="/admin/messages">Messages</a>
      <a href="/admin/logout" class="logout">Logout</a>
    </nav>
  </aside>

  <!-- MAIN -->
  <main class="admin-main">

    <div class="admin-header-flex">
      <div>
        <h1 class="admin-title">Edit Delivered Project</h1>
        <p class="admin-subtitle">Update client delivery details and showcase content.</p>
      </div>

      <a href="/admin/delivered" class="btn btn-outline">Back</a>
    </div>

    <!-- FORM CONTAINER -->
    <div class="form-container">

      <form action="/admin/delivered/<%= project._id %>?_method=PUT"
            method="POST"
            enctype="multipart/form-data"
            class="admin-form">

        <div class="form-grid">

          <!-- LEFT SIDE -->
          <div class="form-column">

            <div class="form-group">
              <label>Project Title</label>
              <input type="text" name="title" value="<%= project.title %>" required>
            </div>

            <div class="form-group">
              <label>Live Link</label>
              <input type="text" name="liveLink" value="<%= project.liveLink %>">
            </div>

            <div class="form-group">
              <label>Description</label>
              <textarea name="description" rows="6" required><%= project.description %></textarea>
            </div>

          </div>

          <!-- RIGHT SIDE -->
          <div class="form-column">

            <div class="form-group">
              <label>Current Image</label>

              <div class="image-preview-box">
                <img src="<%= project.image.url %>" class="current-img-preview" />
              </div>
            </div>

            <div class="form-group">
              <label>Update Image</label>

              <div class="image-upload-wrapper">
                <input type="file" name="image" accept="image/*">

                <div class="upload-placeholder">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24"
                       viewBox="0 0 24 24" fill="none" stroke="currentColor"
                       stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="3" width="18" height="18" rx="2"></rect>
                    <circle cx="8.5" cy="8.5" r="1.5"></circle>
                    <polyline points="21 15 16 10 5 21"></polyline>
                  </svg>
                  <p>Click to upload new image</p>
                </div>
              </div>
            </div>

          </div>

        </div>

        <!-- ACTIONS -->
        <div class="form-actions">
          <button type="submit" class="btn btn-primary">
            Update Delivered Project
          </button>
        </div>

      </form>

    </div>

  </main>
</div>